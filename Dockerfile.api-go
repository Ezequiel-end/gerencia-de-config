FROM golang:1.23-alpine AS builder
WORKDIR /src

RUN apk add --no-cache ca-certificates git

COPY ["APIs para exercícios/api-go/go.mod", "APIs para exercícios/api-go/go.sum", "./"]
RUN go mod download

COPY ["APIs para exercícios/api-go/", "./"]
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /out/api .

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
WORKDIR /app

COPY --from=builder /out/api .

ENV PORT=3000
EXPOSE 3000

USER nobody
CMD ["./api"]
