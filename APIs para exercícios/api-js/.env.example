# Copie para .env: cp .env.example .env
POSTGRES_USER=apijs
POSTGRES_PASSWORD=defina_uma_senha_local
POSTGRES_DB=apijs
POSTGRES_PORT=5432
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=defina_uma_senha_local
PGADMIN_PORT=5050
APP_PORT=3000

# Local sem Docker (opcional)
DB_HOST=localhost
DB_NAME=apijs
DB_USER=apijs
DB_PASSWORD=defina_uma_senha_local
DB_DIALECT=postgres

# Opcional: uma única URL (ex.: Render / CI)
# DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=disable
